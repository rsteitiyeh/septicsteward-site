---
/**
 * SepticSteward landing — flattened from the approved design
 * ("# SepticSteward homeowner hub.zip").
 * Earthy homestead theme (soil green / clay terracotta / cream).
 * Calculator section mounts the shared Tool engine (Calculator.astro)
 * with a SepticSteward skin below.
 */
import site from '../../site.config.json';
import Base from '../layouts/Base.astro';
import Tool from './Tool.astro';
const ls = site.lemonsqueezy.checkoutUrl;
---
<Base
  title="Free Septic Maintenance Schedule &amp; Pumping Calculator | SepticSteward"
  description="Plain-English septic maintenance schedules, pump-out timing, and a free pumping frequency &amp; cost calculator for homeowners."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'How often should a septic tank be pumped?', acceptedAnswer: { '@type': 'Answer', text: 'The U.S. EPA advises homeowners to have a typical household septic system inspected about every three years and the tank pumped every three to five years, depending on household size, tank size, and water use. Use the calculator on this page for an estimate specific to your system.' } },
        { '@type': 'Question', name: 'How much does septic tank pumping cost?', acceptedAnswer: { '@type': 'Answer', text: 'Pump-out cost varies widely by region, tank size, and access. It is a modest, planned expense compared with repairing or replacing a failed drain field. Use the calculator on this page for an estimated regional range.' } },
        { '@type': 'Question', name: 'Can I flush flushable wipes with a septic system?', acceptedAnswer: { '@type': 'Answer', text: 'No. Despite the label, so-called flushable wipes do not break down like toilet paper and can build up in the tank and clog pipes and baffles. Only human waste and toilet paper should be flushed on a septic system.' } },
        { '@type': 'Question', name: 'Do septic additives work?', acceptedAnswer: { '@type': 'Answer', text: 'A healthy septic tank already contains the bacteria it needs. Regular pumping and sensible water use — not additives — are what keep a system working, and some additives can even harm the system.' } },
        { '@type': 'Question', name: 'What are the signs my septic tank is full or failing?', acceptedAnswer: { '@type': 'Answer', text: 'Common warning signs include slow drains throughout the house, gurgling plumbing, sewage odors, and unusually lush or wet patches over the drain field. A backup into the house is often the clearest warning.' } },
        { '@type': 'Question', name: 'Is the pumping calculator accurate?', acceptedAnswer: { '@type': 'Answer', text: "The calculator gives an educational estimate based on household size, tank size, and disposal use. It is a starting point, not a professional assessment — always confirm with an inspection." } }
      ]
    })} />
  </Fragment>

  <a class="skip" href="#main">Skip to content</a>

  <header class="nav">
    <a class="brand" href="#top">
      <svg width="32" height="32" viewBox="0 0 38 38" aria-hidden="true">
        <rect x="4" y="10" width="30" height="22" rx="4" fill="none" stroke="#2F4A2E" stroke-width="2"/>
        <path d="M4 20 h30" stroke="#8FA07B" stroke-width="2"/>
        <path d="M4 26 h30" stroke="#C96F3B" stroke-width="2"/>
        <rect x="12" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
        <rect x="21" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
      </svg>
      <span class="brand-word">Septic<b>Steward</b></span>
    </a>
    <nav aria-label="Main navigation">
      <a href="#how">How It Works</a><a href="#calculator">Calculator</a><a href="/guides/">Guides</a><a href="#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="#hero-form">Free Schedule</a>
  </header>
  <div class="ad">Advertisement</div>

  <main id="main">
    <section id="top" class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Free homeowner guides · EPA-informed</p>
        <h1>Your Septic System Doesn't Have to Be a Mystery.</h1>
        <p class="lede">Plain-English maintenance schedules, pump-out timing, and what-not-to-flush guides for homeowners — free.</p>
        <form class="email" id="hero-form" data-subscribe method="post">
          <label class="sr" for="hero-email">Email address</label>
          <input id="hero-email" name="fields[email]" type="email" required placeholder="you@email.com" />
          <button>Get the Free Schedule</button>
        </form>
        <p class="micro"><b>No sales calls, ever.</b> One helpful email, then the schedule. Unsubscribe anytime.</p>
      </div>
      <figure class="tank-figure">
        <svg viewBox="0 0 460 340" role="img" aria-label="Cutaway diagram of a septic tank showing the scum layer, effluent layer, sludge layer, baffles and drain field.">
          <rect x="0" y="60" width="460" height="280" fill="#e7dcc4"/>
          <rect x="0" y="60" width="460" height="10" fill="#cdbf9f"/>
          <rect x="20" y="92" width="60" height="12" fill="#5C4433"/>
          <rect x="70" y="70" width="300" height="180" rx="10" fill="#fbf6e8" stroke="#5C4433" stroke-width="3"/>
          <rect x="70" y="120" width="300" height="30" fill="#b98a4e"/>
          <rect x="70" y="150" width="300" height="60" fill="#8FA07B"/>
          <rect x="70" y="210" width="300" height="40" fill="#5C4433"/>
          <rect x="96" y="90" width="9" height="120" rx="2" fill="#7a6350"/>
          <rect x="336" y="112" width="9" height="120" rx="2" fill="#7a6350"/>
          <rect x="370" y="150" width="70" height="12" fill="#5C4433"/>
          <g stroke="#5C4433" stroke-width="6" stroke-linecap="round" opacity=".85">
            <line x1="410" y1="180" x2="410" y2="250"/><line x1="410" y1="250" x2="360" y2="250"/><line x1="410" y1="250" x2="450" y2="250"/>
          </g>
          <g font-family="Inter,sans-serif" font-size="10.5" fill="#5C4433">
            <text x="150" y="112" fill="#8a6636">scum layer</text>
            <text x="150" y="168" fill="#3c5a3a">effluent</text>
            <text x="150" y="228" fill="#f5efdf">sludge layer</text>
          </g>
        </svg>
        <figcaption>A working tank separates waste into layers — only the clarified middle layer is meant to move on to the drain field.</figcaption>
      </figure>
    </section>

    <section class="trust">
      <div class="trust-grid">
        <div><h3>Written for homeowners</h3><p>Not for contractors. No jargon you need a license to understand.</p></div>
        <div><h3>Based on EPA &amp; extension guidance</h3><p>We point to SepticSmart and state extension offices — not to whoever's paying.</p></div>
        <div><h3>No sales calls, ever</h3><p>We don't book jobs or resell your info. Just the guides and the tools.</p></div>
      </div>
    </section>
    <div class="ad">Advertisement</div>

    <section id="how" class="section problem">
      <p class="eyebrow">Why maintenance matters</p>
      <h2>A Neglected Tank Is a Quiet, Expensive Problem.</h2>
      <p>Your septic tank works by letting solids settle. Grease and light material float up into the <b>scum layer</b>; heavier solids sink into the <b>sludge layer</b>; only the clarified middle — the <b>effluent</b> — should ever leave the tank for the <b>drain field</b>.</p>
      <p>Skip pump-outs for too long and that sludge builds until solids start pushing past the <b>baffle</b> and into the drain field. Once the drain field clogs, you're into repair or replacement territory, and a <b>backup</b> into the house is often the first warning.</p>
      <div class="callout">
        <p>The EPA advises homeowners to have a typical system <b>inspected about every three years</b> and the tank <b>pumped every three to five years</b>, depending on household size, tank size, and use.</p>
        <span class="src">Source: U.S. EPA SepticSmart. A routine pump-out is a modest, planned cost — a failed drain field is generally far more expensive. Use the calculator below for an estimate rather than treating any single number as a fact.</span>
      </div>
    </section>

    <section id="schedule" class="section magnet">
      <div class="magnet-card">
        <p class="eyebrow">Free download</p>
        <h2>The Septic Maintenance Schedule</h2>
        <p>A one-page, print-and-stick PDF: a <b>seasonal checklist</b>, a <b>pump-out log</b> to track intervals over the years, and a <b>what-not-to-flush fridge sheet</b> for the whole household.</p>
        <form class="email" data-subscribe method="post">
          <label class="sr" for="magnet-email">Email address</label>
          <input id="magnet-email" name="fields[email]" type="email" required placeholder="you@email.com" />
          <button>Send the Schedule</button>
        </form>
        <p class="micro"><b>Instant download link.</b> No spam, no sales calls — unsubscribe anytime.</p>
      </div>
    </section>

    <section id="handbook" class="section offer soil">
      <div class="offer-grid">
        <div>
          <p class="eyebrow light">One-time · optional</p>
          <h2>The Septic Owner's Handbook</h2>
          <p>Everything scattered across the free guides, organized and printable in one place you can keep by the utility panel.</p>
          <p class="honest">Everything on this site is free. The handbook just puts it in one organized, printable place.</p>
        </div>
        <div class="price">
          <strong>$19</strong>
          <p class="price-note">One-time · instant download</p>
          <ul class="check-list">
            <li><span class="check">✓</span><span>Troubleshooting flowcharts for backups, odors &amp; slow drains</span></li>
            <li><span class="check">✓</span><span>The exact questions to ask a pump-out contractor</span></li>
            <li><span class="check">✓</span><span>Inspection checklists you can hand to a pro</span></li>
            <li><span class="check">✓</span><span>The additive truth guide — what actually helps</span></li>
          </ul>
          <a class="btn" href={ls}>Buy the Handbook — $19</a>
          <p class="price-small">Secure checkout via Lemon Squeezy · 30-day guarantee</p>
        </div>
      </div>
    </section>

    <section id="calculator" class="section calc-wrap">
      <p class="eyebrow">Free tool</p>
      <h2>Pumping Frequency &amp; Cost Calculator</h2>
      <p class="section-lede">Answer three questions for an estimated pump-out interval and cost range for a system like yours.</p>
      <Tool />
      <p class="calc-note">Estimates are a starting point, not a professional assessment. Tank condition, water use, and local rules matter — confirm timing with an inspection.</p>
    </section>
    <div class="ad">Advertisement</div>

    <section class="section byline">
      <div class="avatar">{'{{AUTHOR_PHOTO}}'}</div>
      <div>
        <p class="eyebrow">Who's Behind SepticSteward</p>
        <h2>{site.author.name}</h2>
        <p>Our guidance is drawn from public, non-commercial sources — the U.S. EPA's <b>SepticSmart</b> program and <b>state cooperative extension offices</b> — written to be understood by homeowners, not sold by contractors.</p>
        <p>{site.author.bio}</p>
      </div>
    </section>

    <section id="faq" class="section faq">
      <p class="eyebrow">Straight answers</p>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details open><summary>How often should a septic tank be pumped?<span>+</span></summary><p>The U.S. EPA advises inspecting a typical household system about every three years and pumping the tank every three to five years — sooner for larger households or heavy use. The calculator above estimates a range for your system.</p></details>
        <details><summary>How much does septic tank pumping cost?<span>+</span></summary><p>It varies widely by region, tank size, and access — so we won't quote one figure as fact. A routine pump-out is a modest, planned expense; a failed drain field is far costlier. Use the calculator for an estimated regional range.</p></details>
        <details><summary>Can I flush "flushable" wipes?<span>+</span></summary><p>No. Despite the label, they don't break down like toilet paper and can accumulate in the tank and snag on baffles. Only human waste and toilet paper should go down the toilet.</p></details>
        <details><summary>Do septic additives work?<span>+</span></summary><p>A healthy tank already grows the bacteria it needs. Regular pumping and sensible water use — not additives — keep a system working, and some additives can even do harm.</p></details>
        <details><summary>What are the signs my tank is full?<span>+</span></summary><p>Slow drains across the house, gurgling pipes, sewage odors, and soggy or unusually green patches over the drain field are common signals. A backup indoors is the loudest warning.</p></details>
        <details><summary>Is the calculator accurate?<span>+</span></summary><p>It's an educational estimate, not a professional assessment. It weighs household size, tank size, and disposal use — but your tank's real condition and local rates decide the final answer.</p></details>
      </div>
    </section>

    <section class="final soil">
      <h2>Start with the free schedule.</h2>
      <p>Join homeowners keeping their systems healthy the easy way — one email, one printable schedule, zero sales pressure.</p>
      <form class="email center" data-subscribe method="post">
        <label class="sr" for="final-email">Email address</label>
        <input id="final-email" name="fields[email]" type="email" required placeholder="you@email.com" />
        <button>Get the Free Schedule</button>
      </form>
      <p class="micro light">No sales calls, ever. Unsubscribe anytime.</p>
    </section>
  </main>

  <footer>
    <a class="brand" href="#top">
      <svg width="24" height="24" viewBox="0 0 38 38" aria-hidden="true">
        <rect x="4" y="10" width="30" height="22" rx="4" fill="none" stroke="#F5EFDF" stroke-width="2"/>
        <path d="M4 20 h30" stroke="#8FA07B" stroke-width="2"/><path d="M4 26 h30" stroke="#C96F3B" stroke-width="2"/>
      </svg>
      <span class="brand-word sm">Septic<b>Steward</b></span>
    </a>
    <nav><a href="/guides/">Guides</a><a href="#calculator">Calculator</a><a href="#handbook">Handbook</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></nav>
    <p>Some links on this site are affiliate links. If you click through and make a purchase, {site.legalEntity} may earn a commission at no additional cost to you. This helps keep our guides free.</p>
    <small>{site.legalEntity} · © 2026 SepticSteward. Educational information only — not professional engineering or septic advice.</small>
  </footer>
</Base>

<style is:global>
  :root{--soil:#2F4A2E;--soil-deep:#243a23;--cream:#F5EFDF;--cream-2:#EFE7D2;--clay:#C96F3B;--clay-deep:#b25c2c;--sage:#8FA07B;--sage-soft:#d7dcc9;--brown:#5C4433;--brown-soft:#7a6350;--ink:#2b2620;--line:rgba(92,68,51,.22)}
  *{box-sizing:border-box}html{scroll-behavior:smooth}
  body{margin:0;font-family:'Inter',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;color:var(--ink);background:var(--cream);line-height:1.65}
  a{color:var(--clay-deep);text-decoration:none}
  h1,h2{font-family:Georgia,'Times New Roman',serif;color:var(--soil)}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
  .skip{position:absolute;left:-9999px;top:0;z-index:100;background:var(--clay);color:#fff;padding:10px 16px;font-weight:700}
  .skip:focus{left:0}
  .nav{position:sticky;top:0;z-index:50;background:rgba(245,239,223,.94);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);display:flex;align-items:center;gap:clamp(14px,3vw,32px);flex-wrap:wrap;padding:12px clamp(16px,4vw,40px)}
  .brand{display:flex;align-items:center;gap:9px;color:var(--soil)}
  .brand-word{font-family:Georgia,serif;font-weight:700;font-size:20px}.brand-word.sm{font-size:16px}
  .brand-word b{color:var(--clay)}
  .nav nav{display:flex;gap:clamp(12px,2.5vw,26px);flex-wrap:wrap;margin-left:auto}
  .nav nav a{font-size:14.5px;color:var(--brown)}
  .btn,.email button{display:inline-flex;justify-content:center;align-items:center;font-weight:700;background:var(--clay);color:#fff;border:none;cursor:pointer;padding:13px 22px;border-radius:8px;font-size:15px;box-shadow:0 6px 0 var(--clay-deep);transition:.15s}
  .btn:hover,.email button:hover{transform:translateY(-2px)}
  .btn.sm{padding:8px 14px;font-size:13px;box-shadow:none}
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:24px auto;display:grid;place-items:center;border:1px dashed #c9c2b0;border-radius:8px;color:var(--brown-soft);font:11px ui-monospace,monospace;letter-spacing:1.8px;text-transform:uppercase}
  .hero{max-width:1120px;margin:0 auto;padding:clamp(48px,8vw,84px) clamp(20px,5vw,32px);display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center}
  .eyebrow{margin:0 0 14px;color:var(--clay);font-size:12.5px;letter-spacing:1.6px;text-transform:uppercase;font-weight:700}
  .eyebrow.light{color:var(--sage-soft)}
  h1{font-size:clamp(36px,6vw,58px);line-height:1.08;margin:0 0 18px}
  .lede{font-size:18px;color:var(--brown);max-width:520px;margin:0 0 26px}
  .email{display:flex;flex-wrap:wrap;gap:10px;max-width:520px}
  .email.center{justify-content:center;margin:0 auto}
  .email input{flex:1 1 220px;min-width:0;background:#fff;border:1px solid var(--line);color:var(--ink);border-radius:8px;padding:13px 16px;font-size:16px;font-family:inherit}
  .email input:focus{outline:2px solid var(--clay);outline-offset:2px}
  .micro{font-size:13.5px;color:var(--brown-soft);margin:12px 0 0}.micro.light{color:var(--sage-soft)}
  .tank-figure{margin:0}.tank-figure svg{width:100%;height:auto}
  .tank-figure figcaption{font-size:12.5px;color:var(--brown-soft);margin-top:8px}
  .trust{background:var(--cream-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:32px clamp(20px,5vw,40px)}
  .trust-grid{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:26px}
  .trust h3{margin:0 0 6px;font-size:17px;color:var(--soil)}.trust p{margin:0;font-size:14px;color:var(--brown)}
  .section{max-width:820px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px)}
  h2{font-size:clamp(28px,4vw,40px);line-height:1.15;margin:0 0 16px}
  .section-lede{font-size:16.5px;color:var(--brown);max-width:640px}
  .problem p{font-size:16.5px;color:var(--brown)}
  .callout{margin:22px 0 0;padding:20px 24px;background:var(--soil);border-radius:10px;color:var(--cream)}
  .callout p{margin:0 0 8px;font-size:17px;font-weight:600}
  .callout .src{font-size:13px;color:var(--sage-soft)}
  .magnet-card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(28px,5vw,44px)}
  .soil{background:var(--soil);color:var(--cream)}.soil h2{color:var(--cream)}
  .offer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:36px;max-width:1000px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px)}
  .honest{font-style:italic;color:var(--sage-soft);font-size:14px}
  .price{background:#fff;border-radius:12px;padding:28px;color:var(--ink)}
  .price strong{display:block;font-family:Georgia,serif;font-size:48px;color:var(--clay-deep)}
  .price-note{margin:0 0 16px;font-size:14px;color:var(--brown-soft)}
  .check-list{list-style:none;margin:0 0 22px;padding:0;display:grid;gap:10px}
  .check-list li{display:flex;gap:10px;font-size:15px;color:var(--brown)}
  .check{color:var(--clay-deep);font-weight:700}
  .price-small{margin:10px 0 0;font-size:13px;color:var(--brown-soft)}
  .calc-wrap{max-width:900px;text-align:left}
  .calc-note{margin-top:18px;font-size:13.5px;color:var(--brown-soft)}
  .byline{display:flex;gap:28px;flex-wrap:wrap;align-items:flex-start;background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(24px,4vw,36px)}
  .avatar{width:100px;height:100px;border-radius:10px;flex:none;background:var(--cream-2);border:1px dashed var(--brown-soft);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--brown-soft)}
  .faq-list{display:grid;gap:10px}
  .faq details{background:#fff;border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .faq summary{padding:16px 18px;display:flex;justify-content:space-between;gap:16px;cursor:pointer;list-style:none;font-weight:600;color:var(--soil)}
  .faq summary::-webkit-details-marker{display:none}
  .faq details p{margin:0;padding:0 18px 18px;font-size:15px;color:var(--brown)}
  .faq summary span{color:var(--clay);font-size:20px}
  .final{max-width:680px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px);text-align:center}
  .final p{font-size:16.5px;margin:0 0 24px;color:var(--sage-soft)}
  footer{max-width:1120px;margin:0 auto;padding:36px clamp(20px,5vw,32px) 44px}
  footer .brand{margin-bottom:22px}
  footer nav{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:22px}
  footer nav a{font-size:13.5px;color:var(--brown-soft)}
  footer p{font-size:13px;color:var(--brown-soft);line-height:1.7;margin:0 0 8px}
  footer small{font-size:13px;color:var(--brown-soft)}

  /* ---- SepticSteward skin for the shared Tool engine (calculator) ---- */
  .calc{background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(20px,4vw,32px)}
  .calc-sub{color:var(--brown)}
  .calc-field label{color:var(--brown)}
  .calc-field select,.calc-field input{border:1px solid var(--line);border-radius:8px;background:#fbf6e8}
  .calc-results{background:var(--cream-2);border-radius:10px}
  .calc-dose,.calc-unit{color:var(--clay-deep);font-family:Georgia,serif}
  .calc-status{font-weight:700}
  .calc-dot{background:var(--clay)}
  .calc-disclaimer{color:var(--brown-soft)}

  @media(max-width:850px){.nav nav{display:none}.hero{grid-template-columns:1fr}}
  @media(max-width:580px){.hero{padding:56px 16px 60px}h1{font-size:36px}.email{display:grid}}
  @media(prefers-reduced-motion:reduce){*,*:before,*:after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
</style>
