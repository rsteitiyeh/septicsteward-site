---
/**
 * QUIZ ENGINE (archetype A) — config-driven. Covers the 7 exam-prep sites.
 * Reads src/config/tool.json:
 * {
 *   "kind": "quiz",
 *   "heading": "...", "sub": "...",
 *   "mode": "quiz" | "flashcard" | "both",     // Liberty Lane = "both" (flashcards first)
 *   "passLabel": "6 of 10 to pass",            // optional framing
 *   "categories": [ { "id", "label" } ],       // e.g. states, test types, tracks; optional
 *   "questions": [
 *     { "q": "...", "options": ["A","B","C","D"], "answer": 0, "explanation": "...", "category": "id"? }
 *   ]
 * }
 * Flashcard mode uses q + options[answer] as the card back.
 * Styling: neutral base classes; each site skins to its design.
 */
import cfg from '../config/tool.json';
const hasCats = (cfg.categories ?? []).length > 0;
const showModes = cfg.mode === 'both';
---
<div class="quiz" id="tool-quiz" data-tool="quiz">
  <div class="quiz-head">
    <h3>{cfg.heading}</h3>
    {cfg.sub && <p class="quiz-sub">{cfg.sub}</p>}
    <div class="quiz-controls">
      {hasCats && (
        <select id="quiz-cat" aria-label="Choose a category">
          <option value="">All</option>
          {cfg.categories.map((c) => <option value={c.id}>{c.label}</option>)}
        </select>
      )}
      {showModes && (
        <div class="quiz-mode" role="tablist">
          <button id="mode-flash" class="on" type="button">Flashcards</button>
          <button id="mode-quiz" type="button">Practice quiz</button>
        </div>
      )}
    </div>
  </div>

  <!-- flashcard panel -->
  <div class="flash" id="flash-panel" hidden={cfg.mode === 'quiz'}>
    <button class="flash-card" id="flash-card" type="button" aria-live="polite">
      <span class="flash-face flash-front" id="flash-q"></span>
      <span class="flash-face flash-back" id="flash-a" hidden></span>
      <small class="flash-hint">Tap to flip</small>
    </button>
    <div class="flash-actions">
      <button id="flash-known" type="button">I knew it</button>
      <button id="flash-learning" type="button">Still learning</button>
    </div>
    <div class="quiz-progress"><span id="flash-progress"></span></div>
  </div>

  <!-- quiz panel -->
  <div class="qz" id="quiz-panel" hidden={cfg.mode === 'flashcard' || cfg.mode === 'both'}>
    <p class="qz-counter"><span id="qz-counter"></span>{cfg.passLabel && <em> · {cfg.passLabel}</em>}</p>
    <p class="qz-question" id="qz-question" aria-live="polite"></p>
    <div class="qz-options" id="qz-options"></div>
    <p class="qz-explain" id="qz-explain" hidden></p>
    <div class="qz-foot">
      <div class="qz-bar"><span id="qz-bar-fill"></span></div>
      <button id="qz-next" type="button" hidden>Next question</button>
    </div>
    <div class="qz-summary" id="qz-summary" hidden>
      <strong id="qz-score"></strong>
      <p id="qz-verdict"></p>
      <button id="qz-restart" type="button">Try again</button>
    </div>
  </div>
</div>

<script>
  import cfg from '../config/tool.json';
  const $ = (id) => document.getElementById(id);
  const shuffle = (a) => a.map(x => [Math.random(), x]).sort((p, q) => p[0] - q[0]).map(p => p[1]);
  let pool = [], qi = 0, score = 0, answered = false, flashKnown = 0, fi = 0, flipped = false;

  const filterPool = () => {
    const cat = $('quiz-cat')?.value || '';
    pool = shuffle(cfg.questions.filter(q => !cat || q.category === cat)).slice(0, 10);
  };

  /* ---------- flashcards ---------- */
  const flashRender = () => {
    if (!$('flash-panel') || $('flash-panel').hidden) return;
    const q = pool[fi % pool.length];
    $('flash-q').textContent = q.q;
    $('flash-a').textContent = q.options[q.answer] + (q.explanation ? ' — ' + q.explanation : '');
    $('flash-a').hidden = true; $('flash-q').hidden = false; flipped = false;
    $('flash-progress').textContent = `Card ${ (fi % pool.length) + 1 } of ${pool.length} · ${flashKnown} known`;
  };
  $('flash-card')?.addEventListener('click', () => {
    flipped = !flipped;
    $('flash-q').hidden = flipped; $('flash-a').hidden = !flipped;
  });
  $('flash-known')?.addEventListener('click', () => { flashKnown++; fi++; flashRender(); });
  $('flash-learning')?.addEventListener('click', () => { fi++; flashRender(); });

  /* ---------- quiz ---------- */
  const qzRender = () => {
    if (!$('quiz-panel') || $('quiz-panel').hidden) return;
    const q = pool[qi];
    $('qz-summary').hidden = true;
    $('qz-counter').textContent = `Question ${qi + 1} of ${pool.length}`;
    $('qz-question').textContent = q.q;
    $('qz-explain').hidden = true; $('qz-next').hidden = true; answered = false;
    const box = $('qz-options'); box.innerHTML = '';
    q.options.forEach((opt, i) => {
      const b = document.createElement('button');
      b.type = 'button'; b.className = 'qz-opt'; b.textContent = opt;
      b.addEventListener('click', () => {
        if (answered) return; answered = true;
        if (i === q.answer) { b.classList.add('right'); score++; }
        else { b.classList.add('wrong'); box.children[q.answer].classList.add('right'); }
        if (q.explanation) { $('qz-explain').textContent = q.explanation; $('qz-explain').hidden = false; }
        $('qz-next').hidden = false;
      });
      box.appendChild(b);
    });
    $('qz-bar-fill').style.width = `${(qi / pool.length) * 100}%`;
  };
  $('qz-next')?.addEventListener('click', () => {
    qi++;
    if (qi >= pool.length) {
      $('qz-summary').hidden = false;
      $('qz-score').textContent = `${score} / ${pool.length}`;
      $('qz-verdict').textContent = score >= Math.ceil(pool.length * 0.6) ? 'Nice — keep drilling until it feels easy.' : 'Keep practicing — every miss above shows the right answer.';
      $('qz-bar-fill').style.width = '100%';
    } else qzRender();
  });
  $('qz-restart')?.addEventListener('click', () => { qi = 0; score = 0; filterPool(); qzRender(); });

  /* ---------- mode + category ---------- */
  const setMode = (m) => {
    $('flash-panel').hidden = m !== 'flash';
    $('quiz-panel').hidden = m !== 'quiz';
    $('mode-flash')?.classList.toggle('on', m === 'flash');
    $('mode-quiz')?.classList.toggle('on', m === 'quiz');
    m === 'flash' ? flashRender() : qzRender();
  };
  $('mode-flash')?.addEventListener('click', () => setMode('flash'));
  $('mode-quiz')?.addEventListener('click', () => setMode('quiz'));
  $('quiz-cat')?.addEventListener('change', () => { qi = 0; score = 0; fi = 0; flashKnown = 0; filterPool(); flashRender(); qzRender(); });

  filterPool();
  if (cfg.mode === 'flashcard' || cfg.mode === 'both') { flashRender(); }
  if (cfg.mode === 'quiz') { $('quiz-panel').hidden = false; qzRender(); }
</script>

<style is:global>
  .quiz { border-radius: 20px; background: #fff; box-shadow: 0 10px 40px rgba(0,0,0,.12); padding: 32px; }
  .quiz-sub { opacity: .8; }
  .quiz-controls { display: flex; gap: 12px; flex-wrap: wrap; margin: 12px 0 20px; }
  .quiz-controls select { padding: 10px; border-radius: 10px; border: 1px solid #c8d4d6; font: inherit; }
  .quiz-mode button { padding: 8px 14px; border: 1px solid #c8d4d6; background: #f4f7f7; border-radius: 10px; cursor: pointer; font: inherit; }
  .quiz-mode button.on { background: #fff; font-weight: 800; box-shadow: 0 2px 8px rgba(0,0,0,.15); }
  .flash-card { position: relative; display: block; width: 100%; min-height: 180px; padding: 28px; border: 1px solid #d5dde0; border-radius: 16px; background: #fbfdfd; font: inherit; font-size: 18px; cursor: pointer; text-align: center; }
  .flash-hint { position: absolute; bottom: 10px; left: 0; right: 0; font-size: 11px; opacity: .6; }
  .flash-actions { display: flex; gap: 12px; justify-content: center; margin: 16px 0; }
  .flash-actions button { padding: 10px 18px; border: 0; border-radius: 10px; cursor: pointer; font: inherit; font-weight: 700; }
  #flash-known { background: #d8f2df; } #flash-learning { background: #fdeccb; }
  .qz-counter { font-size: 13px; opacity: .8; }
  .qz-question { font-size: 19px; font-weight: 700; }
  .qz-options { display: grid; gap: 10px; }
  .qz-opt { padding: 13px 16px; text-align: left; border: 1px solid #c8d4d6; border-radius: 10px; background: #fbfdfd; cursor: pointer; font: inherit; transition: .15s; }
  .qz-opt:hover { border-color: #7aa5a8; }
  .qz-opt.right { background: #d8f2df; border-color: #2e9e5b; font-weight: 700; }
  .qz-opt.wrong { background: #fbdcd7; border-color: #d24a35; }
  .qz-explain { padding: 12px 16px; border-left: 3px solid #7aa5a8; background: #f2f8f8; }
  .qz-bar { height: 8px; border-radius: 99px; background: #e6eef0; overflow: hidden; margin: 18px 0 12px; }
  .qz-bar span { display: block; height: 100%; width: 0; background: #2e9e5b; transition: width .3s; }
  #qz-next, #qz-restart { padding: 12px 20px; border: 0; border-radius: 10px; background: #26424a; color: #fff; font: inherit; font-weight: 800; cursor: pointer; }
  .qz-summary { text-align: center; padding: 16px 0; }
  .qz-summary strong { font-size: 40px; }
</style>
