---
import site from '../../site.config.json';
interface Props {
  title: string;
  description?: string;
  /** force noindex even post-stealth (e.g. 404, guides while thin) */
  noindex?: boolean;
  ogType?: string;
}
const { title, description = '', noindex = false, ogType = 'website' } = Astro.props;
const robots = site.stealth || noindex ? 'noindex, nofollow' : 'index, follow';
const canonical = new URL(Astro.url.pathname, site.SITE).href;
const ga4 = (site.ga4 && site.ga4.measurementId) || '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
  {ga4 && (
    <Fragment>
      {/* Google Consent Mode v2 — analytics_storage denied until the visitor accepts.
          GA4 still receives cookieless pings while denied, so traffic is measured
          from day one (Raptive requires GA history and it cannot be backfilled). */}
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        var __c = null;
        try { __c = localStorage.getItem('consent-analytics'); } catch (e) {}
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: __c === 'granted' ? 'granted' : 'denied'
        });
      </script>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>
      <script is:inline define:vars={{ ga4 }}>
        gtag('js', new Date());
        gtag('config', ga4);
      </script>
    </Fragment>
  )}
</head>
<body>
  <slot />

  {ga4 && (
    <div id="cookie-banner" class="cookie-banner" hidden>
      <p>
        We use cookies for analytics to understand what's useful here. Ads and
        affiliate links, where present, are always disclosed. See our
        <a href="/privacy/">privacy policy</a>.
      </p>
      <div class="cookie-actions">
        <button type="button" data-consent="denied" class="cookie-btn ghost">Decline</button>
        <button type="button" data-consent="granted" class="cookie-btn">Accept</button>
      </div>
    </div>
  )}

  <script>
    // ---- Cookie consent (interim). Mediavine's CMP replaces this at Journey approval. ----
    const banner = document.getElementById('cookie-banner');
    if (banner) {
      let stored = null;
      try { stored = localStorage.getItem('consent-analytics'); } catch (e) {}
      if (!stored) banner.hidden = false;
      banner.querySelectorAll('[data-consent]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.getAttribute('data-consent');
          try { localStorage.setItem('consent-analytics', v); } catch (e) {}
          if (window.gtag) window.gtag('consent', 'update', { analytics_storage: v });
          banner.hidden = true;
        });
      });
    }
  </script>

  <script>
    // Global subscribe handler: any <form data-subscribe> posts the email to
    // /api/subscribe, which stores it in D1 AND subscribes it to this site's
    // MailerLite group (which triggers magnet delivery + the nurture sequence).
    // The file is also handed over instantly so the visitor never waits on email.
    import site from '../../site.config.json';
    const magnet = site.magnet || {};
    document.querySelectorAll('form[data-subscribe]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = form.querySelector('input[type="email"]');
        const btn = form.querySelector('button');
        const email = input && input.value ? input.value.trim() : '';
        if (!email) return;
        if (btn) { btn.disabled = true; btn.dataset.orig = btn.textContent; btn.textContent = '...'; }
        let ok = false;
        try {
          const r = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email })
          });
          ok = r.ok;
        } catch (err) {}
        const msg = document.createElement('p');
        msg.className = 'subscribe-done';
        if (ok && magnet.file) {
          const a = document.createElement('a');
          a.href = magnet.file; a.download = ''; document.body.appendChild(a); a.click(); a.remove();
          msg.innerHTML = (magnet.doneMessage || 'You are in - your download is starting now.') +
            ' <a href="' + magnet.file + '" download>Download did not start?</a>';
        } else if (ok) {
          msg.textContent = 'You are in - check your inbox.';
        } else {
          msg.textContent = 'Something went wrong - please try again.';
          if (btn) { btn.disabled = false; btn.textContent = btn.dataset.orig; }
        }
        form.insertAdjacentElement('afterend', msg);
        if (ok) form.hidden = true;
      });
    });
  </script>

  <style is:global>
    .cookie-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      display: flex; flex-wrap: wrap; gap: 12px 24px;
      align-items: center; justify-content: center;
      padding: 14px 20px; background: #16181B; color: #F4F2ED;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; font-size: 14px;
      box-shadow: 0 -2px 18px rgba(0,0,0,.22);
    }
    .cookie-banner p { margin: 0; max-width: 70ch; }
    .cookie-banner a { color: inherit; text-decoration: underline; }
    .cookie-actions { display: flex; gap: 10px; }
    .cookie-btn {
      border: 0; border-radius: 6px; padding: 9px 18px; cursor: pointer;
      font: inherit; font-weight: 700; background: #F4F2ED; color: #16181B;
    }
    .cookie-btn.ghost { background: transparent; color: #F4F2ED; border: 1px solid rgba(244,242,237,.45); }
    .cookie-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  </style>

  <style is:global>
:root{--soil:#2F4A2E;--soil-deep:#243a23;--cream:#F5EFDF;--cream-2:#EFE7D2;--clay:#C96F3B;--clay-deep:#b25c2c;--sage:#8FA07B;--sage-soft:#d7dcc9;--brown:#5C4433;--brown-soft:#7a6350;--ink:#2b2620;--line:rgba(92,68,51,.22)}
  *{box-sizing:border-box}html{scroll-behavior:smooth}
  body{margin:0;font-family:'Inter',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;color:var(--ink);background:var(--cream);line-height:1.65}
  a{color:var(--clay-deep);text-decoration:none}
  h1,h2{font-family:Georgia,'Times New Roman',serif;color:var(--soil)}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
  .skip{position:absolute;left:-9999px;top:0;z-index:100;background:var(--clay);color:#fff;padding:10px 16px;font-weight:700}
  .skip:focus{left:0}
  .nav{position:sticky;top:0;z-index:50;background:rgba(245,239,223,.94);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);display:flex;align-items:center;gap:clamp(14px,3vw,32px);flex-wrap:wrap;padding:12px clamp(16px,4vw,40px)}
  .brand{display:flex;align-items:center;gap:9px;color:var(--soil)}
  .brand-word{font-family:Georgia,serif;font-weight:700;font-size:20px}.brand-word.sm{font-size:16px}
  .brand-word b{color:var(--clay)}
  .nav nav{display:flex;gap:clamp(12px,2.5vw,26px);flex-wrap:wrap;margin-left:auto}
  .nav nav a{font-size:14.5px;color:var(--brown)}
  .btn,.email button{display:inline-flex;justify-content:center;align-items:center;font-weight:700;background:var(--clay);color:#fff;border:none;cursor:pointer;padding:13px 22px;border-radius:8px;font-size:15px;box-shadow:0 6px 0 var(--clay-deep);transition:.15s}
  .btn:hover,.email button:hover{transform:translateY(-2px)}
  .btn.sm{padding:8px 14px;font-size:13px;box-shadow:none}
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:24px auto;display:grid;place-items:center;border:1px dashed #c9c2b0;border-radius:8px;color:var(--brown-soft);font:11px ui-monospace,monospace;letter-spacing:1.8px;text-transform:uppercase}
  .hero{max-width:1120px;margin:0 auto;padding:clamp(48px,8vw,84px) clamp(20px,5vw,32px);display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center}
  .eyebrow{margin:0 0 14px;color:var(--clay);font-size:12.5px;letter-spacing:1.6px;text-transform:uppercase;font-weight:700}
  .eyebrow.light{color:var(--sage-soft)}
  h1{font-size:clamp(36px,6vw,58px);line-height:1.08;margin:0 0 18px}
  .lede{font-size:18px;color:var(--brown);max-width:520px;margin:0 0 26px}
  .email{display:flex;flex-wrap:wrap;gap:10px;max-width:520px}
  .email.center{justify-content:center;margin:0 auto}
  .email input{flex:1 1 220px;min-width:0;background:#fff;border:1px solid var(--line);color:var(--ink);border-radius:8px;padding:13px 16px;font-size:16px;font-family:inherit}
  .email input:focus{outline:2px solid var(--clay);outline-offset:2px}
  .micro{font-size:13.5px;color:var(--brown-soft);margin:12px 0 0}.micro.light{color:var(--sage-soft)}
  .tank-figure{margin:0}.tank-figure svg{width:100%;height:auto}
  .tank-figure figcaption{font-size:12.5px;color:var(--brown-soft);margin-top:8px}
  .trust{background:var(--cream-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:32px clamp(20px,5vw,40px)}
  .trust-grid{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:26px}
  .trust h3{margin:0 0 6px;font-size:17px;color:var(--soil)}.trust p{margin:0;font-size:14px;color:var(--brown)}
  .section{max-width:820px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px)}
  h2{font-size:clamp(28px,4vw,40px);line-height:1.15;margin:0 0 16px}
  .section-lede{font-size:16.5px;color:var(--brown);max-width:640px}
  .problem p{font-size:16.5px;color:var(--brown)}
  .callout{margin:22px 0 0;padding:20px 24px;background:var(--soil);border-radius:10px;color:var(--cream)}
  .callout p{margin:0 0 8px;font-size:17px;font-weight:600}
  .callout .src{font-size:13px;color:var(--sage-soft)}
  .magnet-card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(28px,5vw,44px)}
  .soil{background:var(--soil);color:var(--cream)}.soil h2{color:var(--cream)}
  .offer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:36px;max-width:1000px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px)}
  .honest{font-style:italic;color:var(--sage-soft);font-size:14px}
  .price{background:#fff;border-radius:12px;padding:28px;color:var(--ink)}
  .price strong{display:block;font-family:Georgia,serif;font-size:48px;color:var(--clay-deep)}
  .price-note{margin:0 0 16px;font-size:14px;color:var(--brown-soft)}
  .check-list{list-style:none;margin:0 0 22px;padding:0;display:grid;gap:10px}
  .check-list li{display:flex;gap:10px;font-size:15px;color:var(--brown)}
  .check{color:var(--clay-deep);font-weight:700}
  .price-small{margin:10px 0 0;font-size:13px;color:var(--brown-soft)}
  .calc-wrap{max-width:900px;text-align:left}
  .calc-note{margin-top:18px;font-size:13.5px;color:var(--brown-soft)}
  .byline{display:flex;gap:28px;flex-wrap:wrap;align-items:flex-start;background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(24px,4vw,36px)}
  .avatar{width:100px;height:100px;border-radius:10px;flex:none;background:var(--cream-2);border:1px dashed var(--brown-soft);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--brown-soft)}
  .faq-list{display:grid;gap:10px}
  .faq details{background:#fff;border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .faq summary{padding:16px 18px;display:flex;justify-content:space-between;gap:16px;cursor:pointer;list-style:none;font-weight:600;color:var(--soil)}
  .faq summary::-webkit-details-marker{display:none}
  .faq details p{margin:0;padding:0 18px 18px;font-size:15px;color:var(--brown)}
  .faq summary span{color:var(--clay);font-size:20px}
  .final{max-width:680px;margin:0 auto;padding:clamp(48px,7vw,84px) clamp(20px,5vw,32px);text-align:center}
  .final p{font-size:16.5px;margin:0 0 24px;color:var(--sage-soft)}
  footer{max-width:1120px;margin:0 auto;padding:36px clamp(20px,5vw,32px) 44px}
  footer .brand{margin-bottom:22px}
  footer nav{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:22px}
  footer nav a{font-size:13.5px;color:var(--brown-soft)}
  footer p{font-size:13px;color:var(--brown-soft);line-height:1.7;margin:0 0 8px}
  footer small{font-size:13px;color:var(--brown-soft)}

  /* ---- SepticSteward skin for the shared Tool engine (calculator) ---- */
  .calc{background:#fff;border:1px solid var(--line);border-radius:12px;padding:clamp(20px,4vw,32px)}
  .calc-sub{color:var(--brown)}
  .calc-field label{color:var(--brown)}
  .calc-field select,.calc-field input{border:1px solid var(--line);border-radius:8px;background:#fbf6e8}
  .calc-results{background:var(--cream-2);border-radius:10px}
  .calc-dose,.calc-unit{color:var(--clay-deep);font-family:Georgia,serif}
  .calc-status{font-weight:700}
  .calc-dot{background:var(--clay)}
  .calc-disclaimer{color:var(--brown-soft)}

  @media(max-width:850px){.nav nav{display:none}.hero{grid-template-columns:1fr}}
  @media(max-width:580px){.hero{padding:56px 16px 60px}h1{font-size:36px}.email{display:grid}}
  @media(prefers-reduced-motion:reduce){*,*:before,*:after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
  </style>
</body>
</html>
