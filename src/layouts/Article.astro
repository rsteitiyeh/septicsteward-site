      </aside>
      {related.length > 0 && (
        <section class="related">
          <h2>Related guides</h2>
          <ul>
            {related.map(r => (
              <li><a href={`/${r.slug}/`}>{r.title}</a>{r.description && <p>{r.description}</p>}</li>
            ))}
