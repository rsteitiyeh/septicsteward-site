---
import Base from './Base.astro';
import site from '../../site.config.json';
import { extractFaq } from '../lib/faq.mjs';

interface Props {
  entry: any;        // content collection entry
  related?: { title: string; slug: string; description?: string }[];
}
const { entry, related = [] } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;
const updated = updatedDate ?? publishDate;
const authorName = author ?? site.author.name;
const canonical = new URL(`/${entry.id}/`, site.SITE).href;

const faqs = extractFaq(entry.body);
const graph = [];
graph.push({
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: authorName, url: site.SITE },
  publisher: { '@type': 'Organization', name: site.BRAND },
  datePublished: publishDate.toISOString().slice(0, 10),
  dateModified: updated.toISOString().slice(0, 10),
  mainEntityOfPage: canonical
});
if (faqs.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a }
    }))
  });
}
const jsonld = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${title} | ${site.BRAND}`} description={description} ogType="article">
  <script type="application/ld+json" set:html={jsonld} slot="head" />
  <header class="nav">
    <a class="brand" href="/">
      <svg width="32" height="32" viewBox="0 0 38 38" aria-hidden="true">
        <rect x="4" y="10" width="30" height="22" rx="4" fill="none" stroke="#2F4A2E" stroke-width="2"/>
        <path d="M4 20 h30" stroke="#8FA07B" stroke-width="2"/>
        <path d="M4 26 h30" stroke="#C96F3B" stroke-width="2"/>
        <rect x="12" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
        <rect x="21" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
      </svg>
      <span class="brand-word">Septic<b>Steward</b></span>
    </a>
    <nav aria-label="Main navigation">
      <a href="/#how">How It Works</a><a href="/#calculator">Calculator</a><a href="/guides/">Articles</a><a href="/#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="/#hero-form">Free Schedule</a>
  </header>
  <a href="https://463e8mzkvzo7pqjhm71guw2p8d.hop.clickbank.net/?tid=septic_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;flex-direction:column;align-items:center;gap:4px;width:min(970px,calc(100% - 32px));margin:27px auto;text-decoration:none"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.55;color:inherit">Sponsored</span><img src="/images/cb-teds-728x90.gif" width="728" height="90" alt="TedsWoodworking 16,000 project plans" loading="lazy" style="max-width:100%;height:auto;border-radius:6px;box-shadow:0 2px 10px rgba(0,0,0,.12)"></a>
  <main class="article-wrap">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> › <a href="/guides/">Guides</a> › <span>{title}</span>
    </nav>
    <article>
      <header class="article-head">
        <h1>{title}</h1>
        <p class="byline">
          By {authorName} · Updated <time datetime={updated.toISOString().slice(0, 10)}>{fmt(updated)}</time>
        </p>
      </header>
      <div class="prose">
        <slot />
      </div>
      <aside class="cta-card">
        <slot name="cta">
          <p><strong>Try the free tool</strong> — no signup needed.</p>
