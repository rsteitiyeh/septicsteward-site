---
import site from '../../site.config.json';
import Base from '../layouts/Base.astro';
const t = site.theme;
---
<Base title={`Page not found | ${site.BRAND}`} noindex={true}>
  <main class="nf">
    <div>
      <p class="nf-code">404</p>
      <h1>That page isn't here.</h1>
      <p>The link may be old, or the page moved.</p>
      <p><a class="btn" href="/">Back to {site.BRAND}</a> &nbsp; <a href="/guides/">Browse guides</a></p>
    </div>
  </main>
</Base>

<style define:vars={{ bg: t.bg, ink: t.ink, accent: t.accent, headingFont: t.headingFont, bodyFont: t.bodyFont }}>
  .nf { min-height: 80vh; display: grid; place-items: center; text-align: center; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); padding: 24px; }
  .nf-code { font-size: 64px; font-weight: 900; color: var(--accent); margin: 0; }
  h1 { font-family: var(--headingFont); }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 10px; background: var(--accent); color: #fff; font-weight: 700; text-decoration: none; }
</style>
