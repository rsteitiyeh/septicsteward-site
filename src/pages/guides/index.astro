---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
<header class="nav">
    <a class="brand" href="/">
      <svg width="32" height="32" viewBox="0 0 38 38" aria-hidden="true">
        <rect x="4" y="10" width="30" height="22" rx="4" fill="none" stroke="#2F4A2E" stroke-width="2"/>
        <path d="M4 20 h30" stroke="#8FA07B" stroke-width="2"/>
        <path d="M4 26 h30" stroke="#C96F3B" stroke-width="2"/>
        <rect x="12" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
        <rect x="21" y="4" width="5" height="7" rx="1.5" fill="#5C4433"/>
      </svg>
      <span class="brand-word">Septic<b>Steward</b></span>
    </a>
    <nav aria-label="Main navigation">
      <a href="/#how">How It Works</a><a href="/#calculator">Calculator</a><a href="/guides/">Articles</a><a href="/#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="/#hero-form">Free Schedule</a>
  </header>
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=tedsplans&tid=septic_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;flex-direction:column;align-items:center;gap:4px;width:min(970px,calc(100% - 32px));margin:27px auto;text-decoration:none"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.55;color:inherit">Sponsored</span><img src="/images/cb-teds-728x90.gif" width="728" height="90" alt="TedsWoodworking 16,000 project plans" loading="lazy" style="max-width:100%;height:auto;border-radius:6px;box-shadow:0 2px 10px rgba(0,0,0,.12)"></a>
  <main class="guides">
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
  </main>
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=tedsplans&tid=septic_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;flex-direction:column;align-items:center;gap:4px;width:min(970px,calc(100% - 32px));margin:27px auto;text-decoration:none"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.55;color:inherit">Sponsored</span><img src="/images/cb-teds-728x90.gif" width="728" height="90" alt="TedsWoodworking 16,000 project plans" loading="lazy" style="max-width:100%;height:auto;border-radius:6px;box-shadow:0 2px 10px rgba(0,0,0,.12)"></a>
<footer>
    <a class="brand" href="/">
      <svg width="24" height="24" viewBox="0 0 38 38" aria-hidden="true">
        <rect x="4" y="10" width="30" height="22" rx="4" fill="none" stroke="#F5EFDF" stroke-width="2"/>
        <path d="M4 20 h30" stroke="#8FA07B" stroke-width="2"/><path d="M4 26 h30" stroke="#C96F3B" stroke-width="2"/>
      </svg>
      <span class="brand-word sm">Septic<b>Steward</b></span>
    </a>
    <nav><a href="/guides/">Articles</a><a href="/#calculator">Calculator</a><a href="/#handbook">Handbook</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/disclosure/">Disclosure</a><a href="/editorial/">Editorial</a></nav>
    <p>Some links on this site are <a href="/disclosure/">affiliate links</a>. If you click through and make a purchase, we may earn a commission at no additional cost to you. This helps keep our guides free.</p>
    <small>© 2026 SepticSteward. Educational information only — not professional engineering or septic advice.</small>
  </footer>
</Base>

<style>
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
