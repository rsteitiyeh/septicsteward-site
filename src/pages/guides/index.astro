---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Guides | ${site.BRAND}`} description={`All guides from ${site.BRAND}.`}>
  <main class="guides">
    <h1>Guides</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Guides are coming soon.</p>}
  </main>
</Base>

<style>
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
